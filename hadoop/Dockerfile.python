# Fast-build extension: layers Python deps on top of the already-built Hadoop image.
# Use when the base unigap/hadoop:3.3.6 image is already cached locally and you only
# need to (re)install the Spark job's Python dependencies.
FROM unigap/hadoop:3.3.6
COPY requirements-spark.txt /tmp/requirements-spark.txt
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y python3 python3-pip && \
    pip3 install --break-system-packages -r /tmp/requirements-spark.txt && \
    rm -rf /var/lib/apt/lists/*
